# Google Maps native SDK keys — needed for the real map (dev/prod builds only;
# Expo Go uses the stubbed map). Create keys in Google Cloud Console with
# "Maps SDK for iOS" / "Maps SDK for Android" enabled.
GOOGLE_MAPS_API_KEY_IOS=
GOOGLE_MAPS_API_KEY_ANDROID=

# Supabase — defaults to the shared self-hosted instance if unset.
EXPO_PUBLIC_SUPABASE_URL=https://supabase.hangoutstudios.com
EXPO_PUBLIC_SUPABASE_ANON_KEY=
